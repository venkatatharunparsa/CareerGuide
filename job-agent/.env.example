# =============================================================================
# Job Agent — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# Never commit .env to git — it contains secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# Gemini API Keys (Google AI Studio: https://aistudio.google.com/)
# Used for: job planning, semantic scoring, skill extraction, resume tailoring.
# Provide at least one key. Add up to three for automatic rotation on 429 errors.
# -----------------------------------------------------------------------------
GEMINI_API_KEY_1=your_gemini_key_1_here
GEMINI_API_KEY_2=your_gemini_key_2_here
GEMINI_API_KEY_3=your_gemini_key_3_here

# -----------------------------------------------------------------------------
# Tavily API Key (https://tavily.com — free tier: 1000 searches/month)
# Powers internet-wide job search across LinkedIn, Naukri, Indeed, and more.
# Without this key, Tavily scraping is skipped (other sources still work).
# -----------------------------------------------------------------------------
TAVILY_API_KEY=your_tavily_key_here

# -----------------------------------------------------------------------------
# JWT Authentication
# SECRET_KEY: long random string — REQUIRED in production.
# Generate one: python -c "import secrets; print(secrets.token_urlsafe(32))"
# -----------------------------------------------------------------------------
APP_ENV=development
SECRET_KEY=your_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# -----------------------------------------------------------------------------
# Database paths
# CHROMA_PERSIST_PATH: where ChromaDB stores vector embeddings.
# SQLITE_DB_PATH: set automatically in docker-compose.yml for containers.
# Local non-Docker default is handled by backend/app/database.py.
# -----------------------------------------------------------------------------
CHROMA_PERSIST_PATH=./chroma_db
# SQLITE_DB_PATH=/chroma_db/jobagent.db

# -----------------------------------------------------------------------------
# Backend server
# BACKEND_HOST/BACKEND_PORT: uvicorn bind settings (Docker uses 0.0.0.0:8000).
# FRONTEND_URL: added to CORS allow_origins — set to your React app URL.
# -----------------------------------------------------------------------------
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Email notifications (optional)
# Sends a job digest after each agent run.
# GMAIL_APP_PASSWORD: create at https://myaccount.google.com/apppasswords
# Leave blank to disable email notifications.
# -----------------------------------------------------------------------------
GMAIL_SENDER=your_email@gmail.com
GMAIL_APP_PASSWORD=xxxx_xxxx_xxxx_xxxx
NOTIFICATION_EMAIL=your_email@gmail.com

# -----------------------------------------------------------------------------
# Frontend API URL (Docker build-time only — NOT read from this .env file)
# Set in docker-compose.yml or docker-compose.local.yml under:
#   frontend.build.args.VITE_API_URL
# Local:  http://localhost:8000
# EC2:    http://YOUR_EC2_IP:8000
# -----------------------------------------------------------------------------
